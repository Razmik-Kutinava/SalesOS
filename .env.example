# Скопируй в `.env` в корне репозитория (файл в .gitignore).
# В development/test переменные подхватывает gem dotenv-rails.
# См. docs/integrations/OLLAMA-RAILS-INTEGRATION.md
# WSL + Ollama на Windows: 127.0.0.1 в WSL — не тот же localhost, что у Windows; см.
# docs/troubleshooter/2026-03-29-wsl-powershell-ollama-localhost.md

# Базовый URL Ollama API (без завершающего слэша). Порт по умолчанию у Ollama: 11434
OLLAMA_HOST=http://127.0.0.1:11434

# Имя модели, как в `ollama list` (должна быть скачана через `ollama pull`)
OLLAMA_MODEL=llama3.2

# Таймауты HTTP (секунды)
OLLAMA_OPEN_TIMEOUT=5
OLLAMA_READ_TIMEOUT=300

# Эмбеддинги для RAG (должна быть скачана: ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Размер чанка и перекрытие при индексации PDF в базу знаний
# RAG_CHUNK_SIZE=900
# RAG_CHUNK_OVERLAP=120

# RAG-чат на консоли: top-k и порог релевантности (косинус), температура ответа
# RAG_TOP_K=5
# RAG_MIN_SCORE=0.12
# OLLAMA_RAG_TEMPERATURE=0.3

# Температура для распознавания интента (JSON): ниже — стабильнее классификация, 0.0–2.0
OLLAMA_INTENT_TEMPERATURE=0.2
# Второй запрос к Ollama при битом JSON или неверном intent (retry)
OLLAMA_INTENT_RETRY_TEMPERATURE=0.05

# Лимит длины транскрипта до LLM (защита от мусора)
VOICE_TRANSCRIPT_MAX_CHARS=8000

# --- Голос: ASR (см. docs/integrations/LOCAL-WHISPER-SETUP.md, OPENAI-WHISPER-API.md) ---
# Проверка: bin/rails voice:check_asr
# ASR_BACKEND=local_whisper — только whisper.cpp; OPENAI_API_KEY тогда не используется для ASR.
# OPENAI_API_KEY — облачный Whisper; при 429 см. биллинг или переключись на local_whisper.
# ASR_BACKEND=local_whisper
# WHISPER_BIN=C:/path/to/whisper-cli.exe
# WHISPER_MODEL=C:/path/to/ggml-base.bin
# Если whisper собран в WSL (Linux), а Rails на Windows — см. WHISPER_USE_WSL в LOCAL-WHISPER-SETUP.md
# WHISPER_USE_WSL=1
# WHISPER_BIN=/mnt/c/Tools/workarea/SalesOS/whisper.cpp/build/bin/whisper-cli
# WHISPER_MODEL=C:/Tools/workarea/SalesOS/whisper.cpp/models/ggml-base.bin
# Для whisper.cpp без явного значения подставляется ru. Облачный OpenAI: см. OPENAI_WHISPER_LANGUAGE.
# WHISPER_LANGUAGE=ru
# FFMPEG_BIN=C:/Users/YOU/AppData/Local/Microsoft/WinGet/Links/ffmpeg.exe
# VOICE_ASR_STUB=1
# VOICE_ASR_STUB_TEXT=Тестовая фраза без микрофона
# OPENAI_API_KEY=
# OPENAI_WHISPER_MODEL=whisper-1
# Опционально: язык транскрипции (ISO-639-1), например ru — для OpenAI Whisper API
# OPENAI_WHISPER_LANGUAGE=ru
