# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (шаблон коммитим).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Локальный клон whisper.cpp (~сотни МБ; не коммитить)
/whisper.cpp/

# Node (Playwright worker)
/playwright-worker/node_modules/

# Внутренние материалы (навыки/агенты ассистента — не коммитим)
/.claude/

# Внутренняя документация процессов и стека (не коммитим)
/docs/

# Cursor IDE (локальные настройки)
/.cursor/

# macOS
.DS_Store

# Исходники FFmpeg (не бинарник; для работы нужен ffmpeg.exe / winget / FFMPEG_BIN)
/ffmpeg-8.1/

# Ignore key files for decrypting credentials and more.
/config/*.key

